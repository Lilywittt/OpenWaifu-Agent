{
  "defaultTargetIds": [
    "local_archive"
  ],
  "targets": {
    "local_archive": {
      "adapter": "local_archive",
      "displayName": "内部归档",
      "description": "把发布包记录到项目内归档，用于追踪发布历史。",
      "internal": true,
      "archiveRoot": "runtime/service_state/publish/local_archive"
    },
    "qq_bot_user": {
      "adapter": "qq_bot_user",
      "displayName": "QQ Bot User",
      "description": "向指定 QQ 用户推送极简报告。",
      "scene": "user",
      "configPath": "config/publish/qq_bot_message.json",
      "userOpenIdEnvName": "QQ_BOT_USER_OPENID"
    },
    "pixiv_browser_draft": {
      "adapter": "pixiv_browser_draft",
      "displayName": "Pixiv",
      "description": "使用 Edge 登录态打开 Pixiv 投稿页并填好草稿。",
      "postUrl": "https://www.pixiv.net/illustration/create",
      "timeoutSeconds": 90,
      "autoSubmit": false,
      "keepBrowserOpen": true,
      "browserSessionMaxAgeSeconds": 21600
    },
    "instagram_browser_draft": {
      "adapter": "instagram_browser_draft",
      "displayName": "Instagram",
      "description": "使用 Edge 登录态打开 Instagram 创建帖子页，上传图片、填写正文并自动分享。",
      "postUrl": "https://www.instagram.com/",
      "timeoutSeconds": 120,
      "includeSocialTagsInCaption": true,
      "autoSubmit": true,
      "keepBrowserOpen": false,
      "browserSessionMaxAgeSeconds": 21600
    },
    "bilibili_dynamic": {
      "adapter": "bilibili_dynamic",
      "displayName": "Bilibili 动态",
      "description": "使用 Edge 登录态打开 Bilibili 动态页，上传图片、填写正文并自动发布。",
      "postUrl": "https://t.bilibili.com/",
      "timeoutSeconds": 120,
      "includeTitle": false,
      "browserProfilePersistence": "target",
      "autoSubmit": true,
      "keepBrowserOpen": false,
      "browserSessionMaxAgeSeconds": 21600
    },
    "qzone_browser_draft": {
      "adapter": "qzone_browser_draft",
      "displayName": "QQ 空间",
      "description": "使用 Edge 登录态打开 QQ 空间并准备图文说说草稿，由人工确认发布。",
      "postUrl": "https://user.qzone.qq.com/",
      "userIdEnvName": "QZONE_USER_ID",
      "timeoutSeconds": 120,
      "authorizationWaitSeconds": 75,
      "autoSubmit": false,
      "keepBrowserOpen": true,
      "browserSessionMaxAgeSeconds": 21600
    }
  }
}
