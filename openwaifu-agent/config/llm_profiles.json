{
  "profiles": {
    "deepseek_chat": {
      "provider": "deepseek-openai-compatible",
      "baseUrl": "https://api.deepseek.com",
      "chatCompletionsPath": "/chat/completions",
      "envName": "DEEPSEEK_API_KEY",
      "model": "deepseek-v4-pro",
      "thinking": {
        "type": "disabled"
      },
      "temperature": 0.8,
      "maxTokens": 1800,
      "timeoutMs": 180000,
      "retryAttempts": 4,
      "retryBaseDelayMs": 2000,
      "parseRetryAttempts": 4,
      "parseRetryDelayMs": 1200
    },
    "deepseek_reasoner": {
      "provider": "deepseek-openai-compatible",
      "baseUrl": "https://api.deepseek.com",
      "chatCompletionsPath": "/chat/completions",
      "envName": "DEEPSEEK_API_KEY",
      "model": "deepseek-v4-pro",
      "thinking": {
        "type": "enabled"
      },
      "reasoningEffort": "high",
      "temperature": 0.8,
      "maxTokens": 4096,
      "timeoutMs": 180000,
      "retryAttempts": 4,
      "retryBaseDelayMs": 2000,
      "parseRetryAttempts": 4,
      "parseRetryDelayMs": 1200
    }
  },
  "stages": {
    "creative.social_signal_filter": {
      "profile": "deepseek_chat",
      "temperature": 0.2
    },
    "creative.world_design": {
      "profile": "deepseek_chat",
      "temperature": 0.8,
      "topP": 0.9,
      "topK": 50
    },
    "creative.environment_design": {
      "profile": "deepseek_chat",
      "temperature": 0.7
    },
    "creative.styling_design": {
      "profile": "deepseek_chat",
      "temperature": 0.7
    },
    "creative.action_design": {
      "profile": "deepseek_chat",
      "temperature": 0.7
    },
    "social_post.default": {
      "profile": "deepseek_chat",
      "temperature": 1.0,
      "topP": 0.9,
      "topK": 50
    },
    "prompt_builder.default": {
      "profile": "deepseek_chat",
      "temperature": 0.7
    },
    "prompt_guard.default": {
      "profile": "deepseek_chat",
      "temperature": 0.35
    }
  }
}
