{
  "name": "@openwaifu/domain-manage",
  "version": "0.1.0",
  "private": true,
  "description": "OpenWaifu-Agent 域名入口、公共工作台接入与 Cloudflare 部署配置。",
  "type": "module",
  "scripts": {
    "check:homepage-assets": "node ./scripts/check-homepage-assets.mjs",
    "build": "node ./scripts/build-worker.mjs",
    "dev": "npm run build && wrangler dev --local --port 8787",
    "check:homepage": "npm run check:homepage-assets && npm run build && node --check ./dist/worker.js && node --check ./scripts/deploy-worker.mjs && node --check ./scripts/check-homepage-assets.mjs && node --check ./scripts/lib/homepage-assets.mjs",
    "check:workbench": "node --check ./scripts/ensure-public-workbench-domain.mjs && node --check ./scripts/get-public-workbench-runtime.mjs && node --check ./scripts/lib/public-workbench-domain.mjs && node --check ./scripts/lib/public-workbench-runtime.mjs && node --check ./scripts/lib/domain-manage-env.mjs",
    "check": "npm run check:homepage && npm run check:workbench",
    "deploy:homepage": "npm run build && node ./scripts/deploy-worker.mjs",
    "ensure:workbench-domain": "node ./scripts/ensure-public-workbench-domain.mjs",
    "runtime:workbench": "node ./scripts/get-public-workbench-runtime.mjs",
    "refresh:workbench-runtime": "node ./scripts/get-public-workbench-runtime.mjs --refresh",
    "bootstrap:workbench": "powershell -ExecutionPolicy Bypass -File ./scripts/bootstrap-public-workbench-ingress.ps1",
    "bootstrap:workbench:refresh": "powershell -ExecutionPolicy Bypass -File ./scripts/bootstrap-public-workbench-ingress.ps1 -RefreshRuntime",
    "start:workbench": "powershell -ExecutionPolicy Bypass -File ./scripts/start-public-workbench-ingress.ps1",
    "status:workbench": "powershell -ExecutionPolicy Bypass -File ./scripts/status-public-workbench-ingress.ps1",
    "stop:workbench": "powershell -ExecutionPolicy Bypass -File ./scripts/stop-public-workbench-ingress.ps1",
    "deploy": "npm run deploy:homepage && npm run ensure:workbench-domain"
  },
  "devDependencies": {
    "wrangler": "^4.14.1"
  }
}
